# agent-home — example environment.
#
# agent-home itself needs NO secrets. Your tool logins (claude, gh, tailscale)
# live in each tool's own config/keychain — never here. Copy this to `.env`
# only if you want to override one of the optional settings below.

# Where your projects live (default: $HOME/projects)
# AGENT_HOME_PROJECTS="$HOME/projects"

# Plugin marketplace to install (default: gh33k/cc-plugins)
# AGENT_HOME_CC_PLUGINS="gh33k/cc-plugins"

# Homebrew tap that provides `bd` (default: gastownhall/beads)
# AGENT_HOME_BEADS_TAP="gastownhall/beads"
